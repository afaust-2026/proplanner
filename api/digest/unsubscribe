  return `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Unsubscribed — ProPlan Scholar</title>
  <style>
    body{margin:0;padding:0;background:#f0ece3;font-family:'Helvetica Neue',Arial,sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;}
    .card{background:#fff;border-radius:20px;padding:48px 40px;max-width:420px;width:calc(100% - 48px);text-align:center;box-shadow:0 4px 32px rgba(0,0,0,.08);}
    .icon{font-size:48px;margin-bottom:16px;}
    h1{font-size:22px;font-weight:700;color:#0e0e14;margin:0 0 10px;}
    p{font-size:14px;color:#6b6560;line-height:1.6;margin:0 0 24px;}
    a{display:inline-block;background:#c75b12;color:#fff;text-decoration:none;padding:12px 28px;border-radius:100px;font-size:14px;font-weight:600;}
    .note{font-size:12px;color:#9a97a8;margin-top:16px;}
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">✅</div>
    <h1>You've been unsubscribed</h1>
    <p>You'll no longer receive weekly digest emails from ProPlan Scholar. You can re-enable them anytime in Settings → Email Reminders.</p>
    <a href="https://academicplan.pro/app">Back to ProPlan Scholar</a>
