// api/digest/unsubscribe.js
// One-click unsubscribe from weekly digest emails
// URL: academicplan.pro/api/digest/unsubscribe?uid=USER_ID

const SUPABASE_URL = process.env.VITE_SUPABASE_URL || process.env.SUPABASE_URL || '';
const SUPABASE_KEY = process.env.SUPABASE_SERVICE_KEY || '';

export default async function handler(req, res) {
  const { uid } = req.query;

  if (!uid) {
    return res.status(400).send(errorPage('Invalid unsubscribe link', 'This unsubscribe link is missing required information. Please open ProPlan Scholar and turn off email digests in Settings.'));
  }

  try {
    // Update the profile to opt out
    const updateRes = await fetch(`${SUPABASE_URL}/rest/v1/profiles?id=eq.${uid}`, {
      method: 'PATCH',
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': `Bearer ${SUPABASE_KEY}`,
        'Content-Type': 'application/json',
        'Prefer': 'return=minimal',
      },
      body: JSON.stringify({ email_digest: false }),
    });

    if (!updateRes.ok) {
      throw new Error('Database update failed');
    }

    return res.status(200).send(successPage());

  } catch (err) {
    console.error('Unsubscribe error:', err);
    return res.status(500).send(errorPage('Something went wrong', 'We were unable to process your unsubscribe request. Please open ProPlan Scholar and turn off email digests in Settings → Email Reminders.'));
  }
}

