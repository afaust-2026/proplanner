{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/app",
      "dest": "/index.html"
    },
    {
      "src": "/app/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/privacy",
      "dest": "/privacy.html",
      "headers": {
        "content-type": "text/html; charset=utf-8"
      }
    },
    {
      "src": "/terms",
      "dest": "/terms.html",
      "headers": {
        "content-type": "text/html; charset=utf-8"
      }
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)\\.css",
      "dest": "/$1.css"
    },
    {
      "src": "/",
      "dest": "/landing.html"
    }
  ],
  "crons": [
    {
      "path": "/api/digest/send",
      "schedule": "0 23 * * 0"
    },
    {
      "path": "/api/sms/send",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/push/send",
      "schedule": "0 14 * * *"
    }
  ]
}
